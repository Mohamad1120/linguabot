# ── Copy this file to .env and fill in your values ──────────────────────────

# Telegram Bot Token  (from @BotFather)
BOT_TOKEN=8098362649:AAHwwWvykPmDw-5n8QPTelIjkWIGiOBbbVc

# Translation provider: google | deepl | libre
TRANSLATION_PROVIDER=deepl

# Google Cloud Translation API key  (if TRANSLATION_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key_here

# DeepL API key  (if TRANSLATION_PROVIDER=deepl)
DEEPL_API_KEY=7ca370d3-977f-49b8-8fa2-0646f6fea668:fx

# LibreTranslate  (if TRANSLATION_PROVIDER=libre)
LIBRE_API_URL=https://libretranslate.com
LIBRE_API_KEY=

# SQLite database path
DATABASE_PATH=data/linguabot.db

# Cache
CACHE_MAX_SIZE=2000
CACHE_TTL=3600

# Set to 1 to also show the original message below the translation
SHOW_ORIGINAL=0

# Minimum message length to translate (avoids noise from emoji-only messages)
MIN_MESSAGE_LENGTH=2

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
